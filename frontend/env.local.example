# 1. Copy this file to .env.local   2. Set OPENAI_API_KEY   3. From frontend/: npm run dev:local
# (.env.local is gitignored.)

VITE_LOCAL_MODE=true
OPENAI_API_KEY=

# MCP server (Vercel /api/mcp) — server-side only, never VITE_ prefix
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key  # MCP keys, invites, analytics
# MCP_API_SECRET=generate-a-long-random-secret
# MCP_KEY_ENCRYPTION_SECRET=optional-dedicated-secret-for-personal-mcp-keys
