      }
    },
    "/api/mcp/tools/delete_task": {
      "post": {
        "operationId": "delete_task",
        "tags": ["Tasks"],
        "summary": "Delete Task",
        "description": "Delete a task from a board.\n\n**MCP invocation:** `tools/call` with `name: \"delete_task\"`.",
        "security": [
          { "bearerAuth": [], "apiKeyAuth": [] },
