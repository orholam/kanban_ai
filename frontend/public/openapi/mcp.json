          { "bearerAuth": [] }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GetBoardInput" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "MCP tool result",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/GetBoardResult" }
              }
            }
          }
        },
        "x-mcp-tool-name": "get_board"
      }
    },
    "/api/mcp/tools/create_project": {
